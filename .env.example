# =============================================================================
# TravelScribe Environment Variables
# Copy this file to `.env.local` and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase
# Get from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Supabase Storage
# Create a bucket named "travel-photos" in Supabase Storage
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=travel-photos

# -----------------------------------------------------------------------------
# Database — Supabase PostgreSQL (Prisma)
# Get from: Supabase Dashboard → Project Settings → Database
#
# DATABASE_URL = Session pooler (port 5432) — Prisma runtime
# DIRECT_URL   = Session pooler (port 5432) — migrations (same host for Supabase)
# Note: URL-encode special chars in password (@ → %40)
# -----------------------------------------------------------------------------
DATABASE_URL=
DIRECT_URL=

# -----------------------------------------------------------------------------
# AI — Google Gemini (Phase 8+, optional for now)
# Get a free API key: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
