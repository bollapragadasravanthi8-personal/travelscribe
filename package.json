{
  "name": "travelscribe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --hostname 127.0.0.1",
    "dev:clean": "lsof -ti:3000,3001,3002 | xargs kill 2>/dev/null; rm -rf .next && next dev --turbopack --hostname 127.0.0.1",
    "clean": "rm -rf .next",
    "build": "SERWIST_SUPPRESS_TURBOPACK_WARNING=1 next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "node scripts/db-migrate.js",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "storage:setup": "node scripts/ensure-storage-bucket.js",
    "storage:policies": "node scripts/setup-storage-policies.js",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@serwist/next": "^9.5.11",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "embla-carousel-react": "^8.6.0",
    "idb-keyval": "^6.2.5",
    "lucide-react": "^1.20.0",
    "next": "15.5.19",
    "pg": "^8.21.0",
    "radix-ui": "^1.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "serwist": "^9.5.11",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "yet-another-react-lightbox": "^3.32.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
